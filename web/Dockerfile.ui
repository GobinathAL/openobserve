# syntax=docker/dockerfile:1

FROM public.ecr.aws/docker/library/node:24-trixie AS builder
WORKDIR /web

COPY package.json package-lock.json* ./
RUN --mount=type=cache,target=/root/.npm npm ci

COPY . .

ARG VITE_OPENOBSERVE_ENDPOINT=/
ENV VITE_OPENOBSERVE_ENDPOINT=${VITE_OPENOBSERVE_ENDPOINT}

RUN NODE_OPTIONS="--max-old-space-size=8192" npm run build

FROM public.ecr.aws/docker/library/nginx:1.27-alpine AS runtime
COPY nginx.ui.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /web/dist /usr/share/nginx/html

EXPOSE 80
